# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
supabase/.temp/

# customer data exports — never commit imported CSV / XML drops
# (Gumroad / Shopify / Wix dumps, Freshdesk account exports, etc).
# Belt-and-braces: blanket pattern + explicit common drop folders.
*.csv
*.xml
/exports/
/downloads/
/data/
